{
    "manifest_version": 3,
    "name": "Tabs Session Saver",
    "version": "7.1.0",
    "description": "Save and restore your tabs sessions easily",
    "permissions": ["tabs", "storage", "windows", "tabGroups"],
    "action": {
      "default_popup": "popup.html",
      "default_icon": {
        "16": "img-1616.png",
        "32": "img-3232.png",
        "48": "img-4848.png",
        "128": "img-128128.png"
      }
    },
    "background": {
      "service_worker": "background.js"
    },
    "web_accessible_resources": [
      {
        "resources": [
          "welcome.html",
          "welcome.js",
          "img-1616.png",
          "img-3232.png",
          "img-4848.png",
          "img-128128.png"
        ],
        "matches": ["<all_urls>"]
      }
    ]
  }
