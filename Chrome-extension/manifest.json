{
    "manifest_version": 3,
    "name": "Tabs Session Saver",
    "version": "7.15.0",
    "description": "Save and restore your tabs sessions easily",
    "permissions": ["tabs", "storage", "windows", "tabGroups", "alarms", "identity"],
    "host_permissions": [
      "https://tabsessionsaver-newslettersubscribe.paolo-ronco2000.workers.dev/*",
      "https://tabsessionsaver-cloudsync.paolo-ronco2000.workers.dev/*",
      "https://sync.tabsessionsaver.com/*"
    ],
    "icons": {
      "16": "img-1616.png",
      "32": "img-3232.png",
      "48": "img-4848.png",
      "128": "img-128128.png"
    },
    "action": {
      "default_popup": "popup.html",
      "default_icon": {
        "16": "img-1616.png",
        "32": "img-3232.png",
        "48": "img-4848.png",
        "128": "img-128128.png"
      }
    },
    "background": {
      "service_worker": "background.js"
    },
    "oauth2": {
      "client_id": "1061581523479-vmkl5h9abmhttsi5blp7urqa9kd4uh98.apps.googleusercontent.com",
      "scopes": ["openid", "email", "profile"]
    },
    "web_accessible_resources": [
      {
        "resources": [
          "welcome.html",
          "welcome.js",
          "browser-support.js",
          "img-1616.png",
          "img-3232.png",
          "img-4848.png",
          "img-128128.png"
        ],
        "matches": ["<all_urls>"]
      }
    ]
  }
